// 1. OTTIMIZZAZIONE DOWNLOAD (Come nf-core su AWS)
aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

// 2. PARAMETRI GLOBALI
params {
    input            = "data/*_R{1,2}*.fastq.gz"
    outdir           = "results"
    genome           = 'hg38'
    igenomes_base    = 's3://ngi-igenomes/igenomes/'
    bowtie2_index    = null 
    publish_dir_mode = 'copy'
}

// 3. ROBUSTEZZA (Copiato da nf-core)
process.shell = ['/bin/bash', '-euo', 'pipefail']

includeConfig 'conf/igenomes.config'

// 4. PROFILI (Docker/Singularity)
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        docker.registry        = 'quay.io'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

// 3. Gestione Risorse e Pubblicazione Risultati
process {
    // Risorse di default se non specificate sotto
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC {
        cpus   = 2
        memory = '4 GB'
        // I risultati di FastQC andranno in results/fastqc
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }

    withName: TRIMGALORE {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/trimmed", mode: 'copy' ]
    }

    withName: BOWTIE2 {
        cpus   = 8
        memory = '18 GB'
        // Non pubblichiamo il SAM perché è pesante e temporaneo
    }

    withName: SAMTOOLS_SORT {
        cpus   = 4
        memory = '8 GB'
        // Il BAM finale è il nostro risultato principale
        publishDir = [ path: "${params.outdir}/alignment", mode: 'copy' ]
    }
}

// 6. REPORTISTICA (Le tabelle belle che vedi in nf-core)
def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html" }
